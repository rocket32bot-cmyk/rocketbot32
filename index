        function formatTargetDisplay(exerciseKey, target) {
            if (typeof target === 'string') return target;
            if (exerciseKey === 'twists') return `${target} seconds per side`;
            return `${target} reps`;
        }

        function getValidLevel(exerciseKey, level) {
            const exercise = EXERCISES[exerciseKey];
            const maxLevel = exercise.levels.length - 1;
            return Math.min(Math.max(level || 0, 0), maxLevel);
        }

        // Days at current level
        function getDaysAtLevel(exerciseKey) {
            const startDate = userData.levelStartDates?.[exerciseKey];
            if (!startDate) return 0;
            const start = new Date(startDate);
            const now = new Date();
            const diffTime = Math.abs(now - start);
            return Math.ceil(diffTime / (1000 * 60 * 60 * 24));
        }

        // Training duration
        function getTrainingDuration() {
            if (!userData.trainingStartDate) {
                // First workout date
                const firstWorkout = (userData.workoutHistory || [])[0];
                if (firstWorkout) {
                    userData.trainingStartDate = firstWorkout.date;
                } else {
                    return "Just started!";
                }
            }
            const start = new Date(userData.trainingStartDate);
            const now = new Date();
            const weeks = Math.floor((now - start) / (7 * 24 * 60 * 60 * 1000));
            if (weeks < 1) {
                const days = Math.floor((now - start) / (24 * 60 * 60 * 1000));
                return days + " day" + (days !== 1 ? "s" : "");
            }
            return weeks + " week" + (weeks !== 1 ? "s" : "");
        }

        // Workout heatmap data
        function getHeatmapData() {
            const workouts = userData.workoutHistory || [];
            const heatmap = {};
            workouts.forEach(w => {
                const date = new Date(w.date).toISOString().split('T')[0];
                heatmap[date] = (heatmap[date] || 0) + 1;
            });
            return heatmap;
        }

        // Workout page rendering
        function renderWorkout() {
            const today = new Date().getDay();
            const scheduled = WORKOUT_SCHEDULE[today] || [];
            const todayExercises = [...scheduled];
            // Ensure pull-ups are included when push-ups are scheduled
            if (todayExercises.includes('pushups') && !todayExercises.includes('pullups')) {
                todayExercises.push('pullups');
            }
            
            document.getElementById('workout-date').innerHTML = `
                <div style="text-align: center; color: #4a5568; margin-bottom: 15px;">
                    ${new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
                </div>
            `;
            
            if (userData.customWorkout || todayExercises.length === 0) {
                // Show exercise selector
                document.getElementById('exercise-selector').style.display = 'block';
                document.getElementById('workout-exercises').innerHTML = '';
                return;
            }
            
            document.getElementById('exercise-selector').style.display = 'none';
            
            // If a current workout exists for today, sync its levels with current progression
            if (userData.currentWorkout && isSameDay(new Date(userData.currentWorkout.date), new Date())) {
                const cw = userData.currentWorkout;
                Object.keys(cw.exercises || {}).forEach(exKey => {
                    const newLevel = getValidLevel(exKey, userData.levels[exKey] ?? cw.exercises[exKey].level);
                    cw.exercises[exKey].level = newLevel;
                    cw.exercises[exKey].targetSets = getTargetSets(exKey, newLevel);
                    cw.exercises[exKey].repsPerSet = getRepsPerSet(exKey, newLevel);
                });
                renderWorkoutExercises();
                return;
            }

            // Initialize current workout
            userData.currentWorkout = {
                date: new Date().toISOString(),
                exercises: {}
            };
            
            todayExercises.forEach(exerciseKey => {
                const validLevel = getValidLevel(exerciseKey, userData.levels[exerciseKey]);
                userData.currentWorkout.exercises[exerciseKey] = {
                    level: validLevel,
                    targetSets: getTargetSets(exerciseKey, validLevel),
                    completedSets: [],
                    repsPerSet: getRepsPerSet(exerciseKey, validLevel)
                };
            });
            
            // Persist started workout
            if (currentUser) {
                saveUserDataToFirestore();
            } else {
                saveUserData();
            }

            renderWorkoutExercises();
        }

        function confirmCustomExercises() {
            const select = document.getElementById('exercise-select');
            const selectedExercises = Array.from(select.selectedOptions).map(option => option.value);
            
            if (selectedExercises.length === 0) {
                showToast("Please select at least one exercise!");
                return;
            }
            
            // Hide selector
