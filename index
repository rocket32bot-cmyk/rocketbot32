                                if (index < currentLevel) {
                                    status = 'completed';
                                    statusText = 'Completed';
                                } else if (index === currentLevel) {
                                    status = 'current';
                                    statusText = 'Current';
                                }
                                
                                const target = exercise.targets[index];
                                
                                return `
                                    <div class="level-item ${status}">
